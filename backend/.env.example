# RAG CSV Crew Environment Configuration
# Copy this file to .env and fill in your actual values

# Application Settings
APP_NAME=rag-csv-crew
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS Settings (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=rag_csv_crew
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_POOL_MIN_SIZE=2
DATABASE_POOL_MAX_SIZE=10
DATABASE_POOL_TIMEOUT=30.0

# Authentication Settings
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# LLM Configuration - Anthropic (Claude Opus)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-opus-4-5-20251101
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.7

# LLM Configuration - OpenAI (Embeddings)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# CrewAI Configuration
CREWAI_VERBOSE=false
CREWAI_MEMORY=false

# Query Processing Settings
QUERY_TIMEOUT_SECONDS=30
QUERY_MAX_RETRIES=3
QUERY_RETRY_BACKOFF_SECONDS=1,2,4

# Storage Settings
MAX_UPLOAD_SIZE_MB=1000
USER_STORAGE_QUOTA_GB=10

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log
LOG_ROTATION=daily
LOG_RETENTION_DAYS=30
LOG_SECURITY_RETENTION_DAYS=90
LOG_MAX_SIZE_MB=100

# Performance Settings
WORKER_THREADS=4
MAX_CONCURRENT_QUERIES=10
